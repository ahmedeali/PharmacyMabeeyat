<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefWidth="1200.0" prefHeight="700.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ExpiryDashboardController">

    <children>

        <VBox spacing="10" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">

            <HBox spacing="10">
                <Label text="Expiry Dashboard" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Button text="Refresh" onAction="#onRefresh"/>
            </HBox>

            <Label text="Near Expiry Items (Next 90 Days)" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <TableView fx:id="tableNearExpiry" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colNearProduct" text="Product" prefWidth="200"/>
                    <TableColumn fx:id="colNearBatch" text="Batch" prefWidth="150"/>
                    <TableColumn fx:id="colNearExpiry" text="Expiry Date" prefWidth="150"/>
                    <TableColumn fx:id="colNearQty" text="Quantity" prefWidth="100"/>
                </columns>
            </TableView>

            <Label text="Expired Items" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>

            <TableView fx:id="tableExpired" prefHeight="250">
                <columns>
                    <TableColumn fx:id="colExpProduct" text="Product" prefWidth="200"/>
                    <TableColumn fx:id="colExpBatch" text="Batch" prefWidth="150"/>
                    <TableColumn fx:id="colExpExpiry" text="Expiry Date" prefWidth="150"/>
                    <TableColumn fx:id="colExpQty" text="Quantity" prefWidth="100"/>
                </columns>
            </TableView>

        </VBox>

    </children>
</AnchorPane>
