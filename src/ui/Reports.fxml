<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefWidth="1200.0" prefHeight="700.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ReportsController">

    <children>

        <VBox spacing="10" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">

            <HBox spacing="10">
                <Label text="Reports Dashboard" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Button text="Refresh" onAction="#onRefresh"/>
            </HBox>

            <HBox spacing="10">
                <Button text="Daily Sales" onAction="#loadDailySales"/>
                <Button text="Profit Report" onAction="#loadProfitReport"/>
                <Button text="Stock Report" onAction="#loadStockReport"/>
                <Button text="Expiry Report" onAction="#loadExpiryReport"/>
            </HBox>

            <TableView fx:id="tableReports" prefHeight="550">
                <columns>
                    <TableColumn fx:id="col1" text="Column 1" prefWidth="200"/>
                    <TableColumn fx:id="col2" text="Column 2" prefWidth="200"/>
                    <TableColumn fx:id="col3" text="Column 3" prefWidth="200"/>
                    <TableColumn fx:id="col4" text="Column 4" prefWidth="200"/>
                    <TableColumn fx:id="col5" text="Column 5" prefWidth="200"/>
                </columns>
            </TableView>

        </VBox>

    </children>
</AnchorPane>
