<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefWidth="1200.0" prefHeight="700.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.POSController">

    <children>

        <VBox spacing="10" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">

            <HBox spacing="10">
                <TextField fx:id="txtSearch" promptText="Search by name or barcode" prefWidth="400"/>
                <Button text="Add" onAction="#onSearch"/>
            </HBox>

            <TableView fx:id="tableCart" prefHeight="500">
                <columns>
                    <TableColumn fx:id="colProduct" text="Product" prefWidth="250"/>
                    <TableColumn fx:id="colQty" text="Qty" prefWidth="100"/>
                    <TableColumn fx:id="colPrice" text="Price" prefWidth="150"/>
                    <TableColumn fx:id="colTotal" text="Total" prefWidth="150"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Remove Item" onAction="#onRemoveItem"/>
            </HBox>

            <HBox spacing="20" alignment="CENTER_RIGHT">
                <Label text="Payment:"/>
                <ComboBox fx:id="cmbPayment" prefWidth="150"/>

                <Label text="Total:" style="-fx-font-size: 16px;"/>
                <Label fx:id="lblTotal" text="0.0" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                <Button text="Checkout" onAction="#onCheckout" prefWidth="120"/>
            </HBox>

        </VBox>

    </children>
</AnchorPane>