<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefWidth="1200.0" prefHeight="700.0"
            xmlns="http://javafx.com/javafx/8"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.PurchaseController">

    <children>

        <VBox spacing="10" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">

            <HBox spacing="10">
                <TextField fx:id="txtProduct" promptText="Product Name / Barcode" prefWidth="250"/>
                <Button text="Search" onAction="#onSearchProduct"/>

                <TextField fx:id="txtBatch" promptText="Batch Number" prefWidth="150"/>
                <DatePicker fx:id="dpExpiry" promptText="Expiry Date"/>

                <TextField fx:id="txtQty" promptText="Qty" prefWidth="80"/>
                <TextField fx:id="txtBonus" promptText="Bonus" prefWidth="80"/>
                <TextField fx:id="txtPrice" promptText="Purchase Price" prefWidth="120"/>

                <Button text="Add Item" onAction="#onAddItem"/>
            </HBox>

            <TableView fx:id="table" prefHeight="500">
                <columns>
                    <TableColumn fx:id="colProduct" text="Product" prefWidth="200"/>
                    <TableColumn fx:id="colBatch" text="Batch" prefWidth="150"/>
                    <TableColumn fx:id="colQty" text="Qty" prefWidth="80"/>
                    <TableColumn fx:id="colBonus" text="Bonus" prefWidth="80"/>
                    <TableColumn fx:id="colPrice" text="Price" prefWidth="120"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="Remove Item" onAction="#onRemoveItem"/>
            </HBox>

            <HBox spacing="20" alignment="CENTER_RIGHT">
                <Label text="Total:" style="-fx-font-size: 16px;"/>
                <Label fx:id="lblTotal" text="0.0" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Button text="Confirm Purchase" onAction="#onConfirmPurchase" prefWidth="180"/>
            </HBox>

        </VBox>

    </children>
</AnchorPane>
